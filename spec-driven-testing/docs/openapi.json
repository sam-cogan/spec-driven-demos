{
  "openapi": "3.0.1",
  "info": {
    "title": "BookLibrary.Api",
    "version": "1.0.0",
    "description": "Minimal API for managing a small in-memory book library."
  },
  "servers": [
    { "url": "http://localhost:5211" }
  ],
  "paths": {
    "/books": {
      "get": {
        "tags": ["Books"],
        "summary": "List all books",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Book" } }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Books"],
        "summary": "Create a book",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBookRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Book" } }
            },
            "headers": {
              "Location": { "schema": { "type": "string" } }
            }
          },
          "400": { "description": "Validation failed" }
        }
      }
    },
    "/books/{id}": {
      "parameters": [
        { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
      ],
      "get": {
        "tags": ["Books"],
        "summary": "Get a book by id",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Book" } } }
          },
          "404": { "description": "Not found" }
        }
      },
      "put": {
        "tags": ["Books"],
        "summary": "Update a book",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/UpdateBookRequest" } }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Book" } } }
          },
          "400": { "description": "Validation failed" },
          "404": { "description": "Not found" }
        }
      },
      "delete": {
        "tags": ["Books"],
        "summary": "Delete a book",
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "description": "Not found" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Book": {
        "type": "object",
        "required": ["id", "title", "author", "isbn", "copiesTotal", "copiesAvailable"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "author": { "type": "string", "minLength": 1, "maxLength": 200 },
          "isbn": { "type": "string", "pattern": "^(97(8|9))?\\d{9}(\\d|X)$|^[0-9]{3}-[0-9]{10}$" },
          "copiesTotal": { "type": "integer", "minimum": 1 },
          "copiesAvailable": { "type": "integer", "minimum": 0 }
        }
      },
      "CreateBookRequest": {
        "type": "object",
        "required": ["title", "author", "isbn", "copiesTotal"],
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "author": { "type": "string", "minLength": 1, "maxLength": 200 },
          "isbn": { "type": "string", "pattern": "^(97(8|9))?\\d{9}(\\d|X)$|^[0-9]{3}-[0-9]{10}$" },
          "copiesTotal": { "type": "integer", "minimum": 1 }
        }
      },
      "UpdateBookRequest": {
        "type": "object",
        "required": ["title", "author", "isbn", "copiesTotal"],
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 200 },
          "author": { "type": "string", "minLength": 1, "maxLength": 200 },
          "isbn": { "type": "string", "pattern": "^(97(8|9))?\\d{9}(\\d|X)$|^[0-9]{3}-[0-9]{10}$" },
          "copiesTotal": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
